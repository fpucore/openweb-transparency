{
  "manifest_version": 3,
  "name": "OpenWeb Transparency",
  "short_name": "OWT",
  "version": "1.1.0",
  "description": "X-Ray vision for Tech Non-Profits, Foundations, and Wikipedia. Injects real IRS 990 financial data and executive compensation directly into your browser.",
  "author": "Chris McGimpsey-Jones",
"icons": {
    "16": "icons/openweb-transparency-logo_16px.png",
    "32": "icons/openweb-transparency-logo_32px.png",
    "48": "icons/openweb-transparency-logo_48px.png",
    "64": "icons/openweb-transparency-logo_64px.png",
    "128": "icons/openweb-transparency-logo_128px.png",
    "256": "icons/openweb-transparency-logo_256px.png",
    "512": "icons/openweb-transparency-logo_512px.png"
  },
  "action": {
    "default_title": "OpenWeb Transparency"
  },
  "host_permissions": [
    "https://*.wikipedia.org/*",
    "https://*.torproject.org/*",
    "https://*.archive.org/*",
    "https://*.python.org/*",
    "https://*.linuxfoundation.org/*",
    "https://*.mozilla.org/*",
    "https://*.mozilla.com/*",
    "https://*.perlfoundation.org/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.linuxfoundation.org/*"],
      "js": ["owt_linuxfoundation.js"]
    },
    {
      "matches": ["https://*.archive.org/*"],
      "js": ["owt_internetarchive.js"]
    },
    {
      "matches": ["https://*.python.org/*"],
      "js": ["owt_python.js"]
    },
    {
      "matches": ["https://*.torproject.org/*"],
      "js": ["owt_tor.js"]
    },
    {
      "matches": ["https://*.wikipedia.org/*"],
      "js": ["owt_wikipedia.js"]
    },
    {
      "matches": [
        "https://*.mozilla.org/*",
        "https://*.mozilla.com/*"
      ],
      "js": ["owt_mozilla.js"]
    },
    {
      "matches": [
        "https://*.perlfoundation.org/*"],
      "js": ["owt_perl.js"]
    }
  ]
}